# Backend .env for development
APP_NAME=Kloset
APP_ENV=development
APP_PORT=8080
APP_URL=http://localhost:8080
FRONTEND_URL=http://localhost:3000

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_db_password
DB_NAME=kloset
DB_SSLMODE=disable

# JWT
JWT_SECRET=your_super_secret_jwt_key_at_least_32_chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=720h

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_UPLOAD_PRESET=kloset_uploads

# Razorpay
RAZORPAY_KEY_ID=rzp_test_your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# Resend (Email)
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=hello@kloset.in
RESEND_FROM_NAME=Kloset

# AI (Gemini)
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-1.5-flash

# Platform
PLATFORM_FEE_PERCENT=5
MAX_IMAGES_PER_OUTFIT=6
BOOKING_ACCEPT_WINDOW_HOURS=24
SECURITY_DEPOSIT_REFUND_DAYS=3

# Google OAuth
GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com

# Infrastructure & Production Hardening
SENTRY_DSN=
ALLOWED_ORIGINS=http://localhost:3000
LOG_LEVEL=info

# Deployment Platform (Render)
RENDER_EXTERNAL_URL=

# DNS & Security Shielding (Cloudflare)
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_API_TOKEN=

# Operational Webhooks
SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=
UPTIME_WEBHOOK_URL=
