# ─── Kloset Backend — Production Environment ───
# Deployed via Render. All secrets stored in Render Dashboard > Environment.
# This file documents required variables. DO NOT commit real secrets.

# ─── App ───────────────────────────────────────────
APP_NAME=Kloset
APP_ENV=production
APP_PORT=8080
APP_URL=https://api.kloset.in
FRONTEND_URL=https://kloset.in
ALLOWED_ORIGINS=https://kloset.in
LOG_LEVEL=info

# ─── Database (Supabase) ───────────────────────────
# Use Supabase Pooler (Transaction mode) for serverless / connection pooling
# Format: postgresql://user:password@host:6543/dbname?sslmode=require
DB_HOST=__SUPABASE_DB_HOST__
DB_PORT=6543
DB_USER=__SUPABASE_DB_USER__
DB_PASSWORD=__SUPABASE_DB_PASSWORD__
DB_NAME=__SUPABASE_DB_NAME__
DB_SSLMODE=require

# ─── JWT ────────────────────────────────────────────
# Generate with: openssl rand -base64 48
JWT_SECRET=__JWT_SECRET__
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=720h

# ─── Cloudinary ────────────────────────────────────
CLOUDINARY_CLOUD_NAME=__CLOUDINARY_CLOUD_NAME__
CLOUDINARY_API_KEY=__CLOUDINARY_API_KEY__
CLOUDINARY_API_SECRET=__CLOUDINARY_API_SECRET__
CLOUDINARY_UPLOAD_PRESET=kloset_uploads

# ─── Razorpay ──────────────────────────────────────
# Must use rzp_live_ prefix for production
RAZORPAY_KEY_ID=__RAZORPAY_KEY_ID__
RAZORPAY_KEY_SECRET=__RAZORPAY_KEY_SECRET__
RAZORPAY_WEBHOOK_SECRET=__RAZORPAY_WEBHOOK_SECRET__

# ─── Resend (Email) ────────────────────────────────
RESEND_API_KEY=__RESEND_API_KEY__
RESEND_FROM_EMAIL=hello@kloset.in
RESEND_FROM_NAME=Kloset

# ─── AI (Gemini) ──────────────────────────────────
GEMINI_API_KEY=__GEMINI_API_KEY__
GEMINI_MODEL=gemini-1.5-flash

# ─── Platform ──────────────────────────────────────
PLATFORM_FEE_PERCENT=5
MAX_IMAGES_PER_OUTFIT=6
BOOKING_ACCEPT_WINDOW_HOURS=24
SECURITY_DEPOSIT_REFUND_DAYS=3

# ─── Google OAuth ──────────────────────────────────
GOOGLE_CLIENT_ID=__GOOGLE_CLIENT_ID__

# ─── Sentry ────────────────────────────────────────
SENTRY_DSN=__SENTRY_DSN__
