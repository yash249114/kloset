# ==============================================================================
# KLOSET - Production Environment Variable Architecture
# ==============================================================================
# This template defines the complete definitive inventory of environment variables 
# required across all environments (Development, Staging, Production).
# ==============================================================================

# ─── 1. CORE APPLICATION CONFIGURATION ────────────────────────────────────────
APP_NAME=Kloset
APP_ENV=production
APP_PORT=8080
APP_URL=https://api.kloset.in
FRONTEND_URL=https://kloset.in

# ─── 2. DATABASE CONFIGURATION (SUPABASE POSTGRESQL) ─────────────────────────
DB_HOST=aws-1-ap-southeast-1.pooler.supabase.com
DB_PORT=6543
DB_USER=postgres.xxxxxxxxxxxxxxxxxxxx
DB_PASSWORD=your_supabase_pooler_password
DB_NAME=postgres
DB_SSLMODE=require

# ─── 3. JWT SIGNING CONFIGURATION ─────────────────────────────────────────────
# Set to a cryptographically secure 256-bit hash key in production
JWT_SECRET=your_production_jwt_signing_key_secret
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=720h

# ─── 4. CLOUDINARY INTEGRATION (MEDIA UPLOADS & STORAGE) ──────────────────────
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
CLOUDINARY_UPLOAD_PRESET=kloset_uploads

# ─── 5. RAZORPAY PAYMENT GATEWAY INTEGRATION ──────────────────────────────────
RAZORPAY_KEY_ID=rzp_live_your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# ─── 6. RESEND TRANSACTIONAL EMAIL SERVICE ────────────────────────────────────
RESEND_API_KEY=re_your_live_resend_api_key
RESEND_FROM_EMAIL=hello@kloset.in
RESEND_FROM_NAME=Kloset

# ─── 7. GEMINI AI (MODEL & VERIFICATION CONFIG) ──────────────────────────────
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash

# ─── 8. GOOGLE OAUTH SECURITY CLAIMS VALIDATOR ────────────────────────────────
GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com

# ─── 9. BUSINESS PLATFORM RULE CONTROLS ──────────────────────────────────────
PLATFORM_FEE_PERCENT=5
MAX_IMAGES_PER_OUTFIT=6
BOOKING_ACCEPT_WINDOW_HOURS=24
SECURITY_DEPOSIT_REFUND_DAYS=3

# ─── 10. INFRASTRUCTURE EXTRA SECURITY & TELEMETRY CONTROL ────────────────────
SENTRY_DSN=https://your_sentry_dns_key@sentry.io/project-id
ALLOWED_ORIGINS=https://kloset.in
LOG_LEVEL=warn

# ─── 11. DEPLOYMENT PLATFORM SPECIAL PLACEMENTS ──────────────────────────────
# Render environment auto-populated key
RENDER_EXTERNAL_URL=https://api.kloset.in

# Vercel environment status flags
VERCEL_ENV=production

# ─── 12. CDN & DNS CONTROL (CLOUDFLARE SHIELDING) ────────────────────────────
CLOUDFLARE_ZONE_ID=your_cloudflare_zone_id
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token

# ─── 13. OPERATIONAL WEBHOOK CHANNELS (OPTS) ──────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxx/yyy
UPTIME_WEBHOOK_URL=https://heartbeat.uptime.example/ping

# ==============================================================================
# NEXT.JS FRONTEND STOREFRONT PROPERTIES (.env.production / Vercel Settings)
# ==============================================================================
NEXT_PUBLIC_API_URL=https://api.kloset.in/api/v1
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=kloset_uploads
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_live_your_razorpay_key_id
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com
NEXT_PUBLIC_SENTRY_DSN=https://your_sentry_dns_key@sentry.io/project-id
NEXT_PUBLIC_POSTHOG_KEY=phc_your_posthog_client_key
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
